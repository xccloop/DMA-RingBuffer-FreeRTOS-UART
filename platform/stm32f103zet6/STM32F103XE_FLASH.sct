;******************************************************************************
; @file     STM32F103XE_FLASH.sct
; @brief    Scatter-loading linker script for STM32F103ZET6 (512KB Flash, 64KB RAM)
;           Keil MDK ARMCC / ARMCLANG
;
; Memory layout:
;   FLASH: 0x08000000, 512KB (0x80000)
;   RAM:   0x20000000, 64KB  (0x10000)
;******************************************************************************

LR_IROM1 0x08000000 0x00080000  {    ; load region size_region
  ER_IROM1 0x08000000 0x00080000  {  ; load address = execution address
   *.o (RESET, +First)
   *(InRoot$$Sections)
   .ANY (+RO)
   .ANY (+XO)
  }
  RW_IRAM1 0x20000000 0x00010000  {  ; RW data
   .ANY (+RW +ZI)
  }
}
