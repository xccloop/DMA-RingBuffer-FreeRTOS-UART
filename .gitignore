# ============================================
# STM32 / Keil MDK-ARM Project .gitignore
# ============================================

# --- Keil user-specific settings ---
*.uvoptx
*.uvguix.*
*.uvguix

# --- Build output directory ---
Output/
*.build_log.htm

# --- Compiled objects ---
*.o
*.d

# --- Linker & executable artifacts ---
*.axf
*.hex
*.bin
*.map
*.lnp
*.dep
*.crf
*.htm

# --- Listing files ---
*.lst

# --- Scatter / linker scripts ---
*.scr
*.sct
*.iex

# --- Preprocessor intermediates ---
*._i
*.__i

# --- Debugger settings ---
JLinkLog.txt
JLinkSettings.ini
*.DebugConfig
*.ReleaseConfig

# --- RTE generated ---
RTE/

# --- OS generated files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Editor / IDE ---
*.swp
*.swo
*~
.vscode/
.idea/

# --- Python __pycache__ (if any script tools) ---
__pycache__/
*.pyc
